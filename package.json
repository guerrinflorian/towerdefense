{
  "name": "javascript",
  "version": "1.0.0",
  "description": "The JavaScript template",
  "type": "module",
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "start:no-watch": "concurrently \"npm run server\" \"npm run client:no-watch\"",
    "client": "cross-env PORT=1234 parcel ./index.html",
    "client:no-watch": "cross-env PORT=1234 parcel serve ./index.html --no-hmr",
    "build": "parcel build ./index.html",
    "server": "node server/index.js",
    "dev:server": "nodemon server/index.js"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "babel-eslint": "^10.1.0",
    "buffer": "^6.0.3",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "eslint": "^7.2.0",
    "nodemon": "^3.1.7",
    "parcel": "^2.0.0"
  },
  "keywords": [
    "css",
    "javascript"
  ]
}
